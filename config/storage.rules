rules_version = '2';
// ==========================================
// XPARQ Firebase Storage Rules
// ==========================================
service firebase.storage {
  match /b/{bucket}/o {

    // ── Profile Photos ─────────────────────────────────────────────────────
    // Path: /users/{uid}/profile.jpg
    match /users/{uid}/profile.jpg {
      // Any authenticated user can read (for displaying avatars)
      allow read: if request.auth != null;

      // Only the owner can upload their own photo
      // Constraints: max 5MB, image files only
      allow write: if request.auth.uid == uid
          && request.resource.size < 5 * 1024 * 1024
          && request.resource.contentType.matches('image/.*');

      // No client deletes (admin SDK only)
      allow delete: if false;
    }

    // ── Profile Photo Thumbnails ───────────────────────────────────────────
    // Generated automatically by Cloud Functions resize extension
    match /users/{uid}/profile_thumb.jpg {
      allow read: if request.auth != null;
      allow write, delete: if false; // Cloud Functions only
    }

    // ── Default: deny all ─────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
